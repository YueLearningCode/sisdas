{
  "input_path":"dataset\\used_car_realistic_marketstyle.csv",
  "target_column":"price_rp",
  "test_size":0.2,
  "random_state":42,
  "scale_numeric":false,
  "remove_outliers":false,
  "rows_before_outlier_removal":2000,
  "rows_after_preprocessing":2000,
  "train_rows":1600,
  "test_rows":400,
  "numeric_columns":[
    "year",
    "mileage_km",
    "engine_size_cc",
    "owner_count"
  ],
  "categorical_columns":[
    "brand",
    "transmission",
    "fuel_type",
    "condition",
    "location",
    "color"
  ],
  "dropped_columns":[
    "car_name",
    "instalment_rp_monthly"
  ],
  "output_files":[
    "train_processed.csv",
    "test_processed.csv",
    "outlier_summary.csv",
    "preprocessor.joblib"
  ]
}